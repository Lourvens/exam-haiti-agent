# =============================================================================
# Application
# =============================================================================
APP_NAME="Exam Haiti Agent"
APP_VERSION="0.1.0"
DEBUG=false

# API
API_PREFIX="/api/v1"

# =============================================================================
# LLM Configuration
# =============================================================================
LLM_PROVIDER=openai

# OpenAI (required for LLM)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1  # Optional: custom endpoint

# Anthropic (optional)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google (optional)
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_MODEL=gemini-2.0-flash

# =============================================================================
# Embeddings Configuration
# =============================================================================
EMBEDDING_PROVIDER=auto  # auto, openai, or huggingface
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# OpenAI Embeddings (used if OPENAI_API_KEY is set)
# Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# HuggingFace Embeddings (used if HF_TOKEN is set)
# Options: sentence-transformers/all-MiniLM-L6-v2, sentence-transformers/all-mpnet-base-v2
#          intfloat/e5-base-v2, intfloat/e5-small-v2
# HF_TOKEN=your_huggingface_token_here
# HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Chroma Vector Store
# =============================================================================
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION_NAME=exam_chunks

# =============================================================================
# Chunking Configuration
# =============================================================================
CHUNK_MAX_TOKENS=1000
CHUNK_OVERLAP_TOKENS=100

# =============================================================================
# Storage
# =============================================================================
PDF_STORAGE_PATH=data/pdfs

# =============================================================================
# Logging
# =============================================================================
LOG_DIRECTORY=logs
LOG_LEVEL=INFO
LOG_ROTATION=1 day
LOG_RETENTION=30 days


# =============================================================================
# Admin
# =============================================================================
ADMIN_PASSWORD=your_admin_password_here

# =============================================================================
# Neo4j Graph Database
# =============================================================================
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j
